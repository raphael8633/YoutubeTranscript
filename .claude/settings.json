{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"cat MISTAKES.md 2>/dev/null || true\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git rebase:*)",
      "Bash(git pull --rebase:*)",
      "Bash(git worktree:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git branch:*)",
      "Bash(git mv:*)",
      "Bash(git check-ignore:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run python -m pytest:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(gh workflow:*)",
      "Bash(gh run:*)",
      "Bash(gh cache:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(grep:*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  }
}
